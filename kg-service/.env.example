# Port the KG service listens on (default 8001)
PORT=8001

# Origins allowed to make cross-origin requests (browser → kg-service).
# Normally only the chatbot-server needs access.
CORS_ORIGINS=http://localhost:8000

# Set to "production" to disable /docs and /redoc
APP_ENV=development

# Logging: INFO for minimal output, DEBUG for full request/response traces
LOG_LEVEL=INFO

# Any OpenAI-compatible /embeddings endpoint. Defaults to LM Studio; load an
# embedding model there (e.g. nomic-embed-text-v1.5 or mxbai-embed-large-v1).
EMBEDDING_BASE_URL=http://localhost:1234/v1
EMBEDDING_API_KEY=lm-studio
EMBEDDING_MODEL=text-embedding-mxbai-embed-large-v1
EMBED_MATCH_THRESHOLD=0.7
ENABLE_EMBEDDING_LINKING=true

# --- Forward-chaining rule materialization -----------------------------------
# Materializes transitive closures, subclass/domain/range type propagation, etc.
ENABLE_RULE_MATERIALIZATION=true
