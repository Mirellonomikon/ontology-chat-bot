# LM Studio (local instance – https://lmstudio.ai)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# OpenRouter – https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Gemini / AI Studio – https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# App
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Set to "production" to disable /docs and /redoc
APP_ENV=development

# Knowledge-graph microservice
KG_SERVICE_URL=http://localhost:8001

# LLM ontology induction at upload time (uses the selected provider/model to
# propose classes, subclass hierarchy and named relations for tabular files).
ENABLE_LLM_INDUCTION=true

# Token budget for the induction call. The proposal JSON is small, but reasoning
# models spend tokens "thinking" first — raise this (e.g. 8192) if induction fails
# or falls back to heuristics with a reasoning model.
INDUCTION_MAX_TOKENS=4096

# Logging: INFO for minimal output, DEBUG for full request/response traces
LOG_LEVEL=INFO
